# ── Notification endpoint (notify.php on XAMPP) ─────────────────────────────
# Default: http://localhost/Office_Website/notify.php
# Change this only if your domain or folder structure differs.
# VITE_NOTIFY_URL=http://localhost/Office_Website/notify.php

# ── Production deployment ────────────────────────────────────────────────────
# When hosting live, set this to your actual domain:
# VITE_NOTIFY_URL=https://yourdomain.com/notify.php
