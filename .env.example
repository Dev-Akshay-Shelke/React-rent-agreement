# Twilio WhatsApp (set in Netlify environment variables)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_WHATSAPP_TO=whatsapp:+918483043373
# TWILIO_CONTENT_SID=HXb5b62575e6e4ff6129ad7c8efe1f983e

# Optional: override notification endpoint while developing locally.
# Example with Netlify dev: VITE_NOTIFY_URL=http://localhost:8888/.netlify/functions/send-whatsapp
# If not set, app uses relative path /.netlify/functions/send-whatsapp
